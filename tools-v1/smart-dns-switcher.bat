@echo off
setlocal EnableExtensions DisableDelayedExpansion
chcp 65001 >nul
net session >nul 2>&1
if not "%ERRORLEVEL%"=="0" (
  powershell.exe -NoProfile -Command "Start-Process -FilePath '%ComSpec%' -ArgumentList '/c ""%~f0""' -Verb RunAs"
  if not "%ERRORLEVEL%"=="0" (
    echo Administrator permission was not granted. No network settings were changed.
    pause
  )
  exit /b
)
set "DNS_SWITCHER_SELF=%~f0"
goto :launch_fixed
set "DNS_SWITCHER_"
powershell.exe -NoProfile -ExecutionPolicy Bypass -EncodedCommand 
set "RC=%ERRORLEVEL%"
if not "%RC%"=="0" (
  echo.
  echo The tool ended with exit code: %RC%
  pause
)
endlocal & exit /b %RC%

:launch_fixed
goto :launch_standalone
powershell.exe -NoProfile -ExecutionPolicy Bypass -EncodedCommand 
set "RC=%ERRORLEVEL%"
if not "%RC%"=="0" (
  echo.
  echo The tool ended with exit code: %RC%
  pause
)
endlocal & exit /b %RC%

:launch_standalone
powershell.exe -NoProfile -ExecutionPolicy Bypass -EncodedCommand 
set "RC=%ERRORLEVEL%"
if not "%RC%"=="0" (
  echo.
  echo The tool ended with exit code: %RC%
  pause
)
endlocal & exit /b %RC%
